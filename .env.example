# ==== Serveur ====
PORT=5000
NODE_ENV=development

# ==== Base de données PostgreSQL ====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecokin
DB_USER=postgres
DB_PASSWORD=mot_de_passe_postgres

# ==== Frontend / CORS ====
# Ancienne variable conservée pour compatibilité.
FRONTEND_URL=http://localhost:5501

# Recommandé : plusieurs origines séparées par des virgules.
# Exemple : interface publique 5501, utilisateur 5502, admin 5503.
FRONTEND_URLS=http://localhost:5501,http://localhost:5502,http://localhost:5503
FRONTEND_PUBLIC_URL=http://localhost:5501
FRONTEND_USER_URL=http://localhost:5502
FRONTEND_ADMIN_URL=http://localhost:5503

# Page front utilisée dans le lien email de mot de passe oublié.
FRONTEND_RESET_PASSWORD_PATH=/reset-password.html

# ==== Sessions ====
SESSION_DURATION_DAYS=7
SESSION_COOKIE_NAME=ecokin_session

# ==== Email (mot de passe oublié) ====
# Si non configuré, le lien de réinitialisation est simplement loggé
# en console (mode dev) au lieu d'être envoyé par email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ecokin.cd
